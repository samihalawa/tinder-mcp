{
  "name": "tinder-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for automating Tinder operations - authentication, profile management, swiping, messaging, and settings configuration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "tinder-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && npm start",
    "test": "node scripts/test-mcp.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.41.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tinder",
    "automation",
    "browser-automation",
    "dating",
    "social",
    "messaging"
  ],
  "author": "Sami Halawa",
  "license": "MIT"
}
